# Dependências (pasta enorme, não entra no controle de versão)
node_modules/

# Arquivos gerados pelo build
dist/
release/

# Banco de dados local (cada máquina tem o seu)
database/*.db
database/*.db-shm
database/*.db-wal

# Variáveis de ambiente (senhas, chaves — nunca versionar)
.env
.env.local

# Sistemas operacionais
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Editor
.vscode/settings.json
